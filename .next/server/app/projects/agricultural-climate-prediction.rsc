0:["6SLC_auuWq2-FrbuNTQws",[[["",{"children":["projects",{"children":["agricultural-climate-prediction",{"children":["__PAGE__",{}]}]}]},"$undefined","$undefined",true],["",{"children":["projects",{"children":["agricultural-climate-prediction",{"children":["__PAGE__",{},[["$L1",["$","section",null,{"className":"section","children":["$","div",null,{"className":"container article","children":[["$","p",null,{"className":"breadcrumb","children":"Home / Projects / Agricultural Climate Prediction"}],["$","h1",null,{"children":"Agricultural Climate Prediction using Machine Learning"}],["$","img",null,{"className":"project-hero-image","src":"/images/climate-project.svg","alt":"Agricultural climate prediction data science project with NASA POWER and machine learning"}],["$","p",null,{"children":"This data science project analyzes climate conditions in Radès to support agricultural planning. It uses five years of meteorological data to study temperature, precipitation, humidity, heatwaves and frost risk."}],["$","div",null,{"className":"kpi-grid","children":[["$","div",null,{"className":"kpi","children":[["$","strong",null,{"children":"5 years"}],["$","span",null,{"children":"climate data"}]]}],["$","div",null,{"className":"kpi","children":[["$","strong",null,{"children":"NASA"}],["$","span",null,{"children":"POWER API"}]]}],["$","div",null,{"className":"kpi","children":[["$","strong",null,{"children":"MAE 1.77°C"}],["$","span",null,{"children":"best model"}]]}],["$","div",null,{"className":"kpi","children":[["$","strong",null,{"children":"Radès"}],["$","span",null,{"children":"agricultural planning"}]]}]]}],["$","h2",null,{"children":"Project Objective"}],["$","p",null,{"children":"The objective is to understand climate patterns in Radès and build a predictive model that estimates the maximum temperature of the next day. The final goal is to help optimize the agricultural calendar and improve irrigation decisions."}],["$","h2",null,{"children":"Data Source"}],["$","p",null,{"children":"The dataset comes from the NASA POWER API. The collected variables include minimum temperature, maximum temperature, relative humidity, wind speed, solar radiation and daily precipitation."}],["$","h2",null,{"children":"Data Cleaning"}],["$","p",null,{"children":"The preprocessing phase handles missing values, converts wind units, corrects date formats, removes duplicates and anomalies, and standardizes data types to prepare a clean dataset for analysis and modeling."}],["$","h2",null,{"children":"Feature Engineering"}],["$","p",null,{"children":"New variables are created to better capture climate dynamics, including month, day, weekday, season, heatwave indicators, frost day indicators, rainy day indicators and the next-day maximum temperature target."}],["$","h2",null,{"children":"Exploratory Data Analysis"}],["$","ul",null,{"children":[["$","li",null,{"children":"Radès shows very hot and dry summers with high irrigation needs."}],["$","li",null,{"children":"Rainfall is irregular, with many days at 0 mm."}],["$","li",null,{"children":"Heatwaves mainly occur between June and September."}],["$","li",null,{"children":"Frost risk is low because winters are generally mild."}],["$","li",null,{"children":"Low humidity in summer increases water stress for crops."}]]}],["$","h2",null,{"children":"Predictive Modeling"}],["$","p",null,{"children":"Three models are compared: Linear Regression, Decision Tree and KNN. Linear Regression achieved the best performance, with a MAE of about 1.77°C, making it the most reliable model for predicting tomorrow’s maximum temperature in this project."}],["$","h2",null,{"children":"Agricultural Impact"}],["$","p",null,{"children":"The model helps anticipate hot days and supports better irrigation planning. Based on the analysis, an agricultural calendar for tomato cultivation in Radès is proposed, covering sowing, transplanting, flowering, fruiting and harvesting periods."}]]}]}],null],null],null]},[null,["$","$L2",null,{"parall