h2",null,{"children":"Data Warehouse Preparation"}],["$","p",null,{"children":"Before creating the cube, the data is cleaned and organized into a data warehouse. A fact table stores numeric measures, while dimension tables describe the context of analysis such as date, device, campaign, location and advertisement."}],["$","h2",null,{"children":"Cube Design"}],["$","p",null,{"children":"The SSAS cube connects measures from the fact table with business dimensions. This design allows aggregated results to be calculated by the OLAP engine, making analysis easier and faster than querying raw tables directly."}],["$","h2",null,{"children":"OLAP Operations Applied"}],["$","ul",null,{"children":[["$","li",null,{"children":"Drill-down: analyze data from year to quarter, month and day."}],["$","li",null,{"children":"Roll-up: summarize detailed daily results into monthly or yearly totals."}],["$","li",null,{"children":"Slice: filter the cube by one dimension, for example Device = Mobile."}],["$","li",null,{"children":"Dice: filter by several dimensions such as device, location and campaign."}],["$","li",null,{"children":"Pivot: change the view of dimensions to compare results from different angles."}]]}],["$","h2",null,{"children":"Measures and KPIs"}],["$","ul",null,{"children":[["$","li",null,{"children":"Impressions"}],["$","li",null,{"children":"Clicks"}],["$","li",null,{"children":"Conversions"}],["$","li",null,{"children":"Cost"}],["$","li",null,{"children":"Sales amount"}],["$","li",null,{"children":"Click-through rate and conversion analysis"}],["$","li",null,{"children":"Campaign performance comparison"}]]}],["$","h2",null,{"children":"MDX Analysis"}],["$","p",null,{"children":"MDX queries are used to explore the cube and retrieve aggregated results. This makes it possible to compare marketing performance by campaign, device, location and time period while keeping the analysis structured and reusable."}],["$","h2",null,{"children":"Skills Applied"}],["$","p",null,{"children":"This project demonstrates knowledge of dimensional modeling, data warehouse preparation, SSAS cube creation, OLAP operations, KPI analysis, MDX querying and business-oriented interpretation of marketing data."}]]}]}],null],null],null]},[null,["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children","projects","children","ssas-olap-cube-analysis","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[null,["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children","projects","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/ba9020230c6dd994.css","precedence":"next","crossOrigin":"$undefined"}]],["$","html",null,{"lang":"en","children":["$","body",null,{"children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Chayma Chouikh\",\"jobTitle\":\"BI Student and Data Analyst\",\"url\":\"https://your-domain.com\",\"sameAs\":[\"https://www.linkedin.com/in/chayma-chouikh/\"],\"knowsAbout\":[\"Business Intelligence\",\"Data Analysis\",\"SQL\",\"Power BI\",\"Python\",\"Machine Learning\",\"SSIS\",\"SSAS\",\"OLAP Cubes\",\"Data Warehousing\",\"Dashboards\",\"Reporting\"]}"}}],["$","header",null,{"className":"header","children":["$","nav",null,{"className":"container nav","aria-label":"Main navigation","children":[["$","$L4",null,{"href":"/","className":"logo","aria-label":"Chayma Chouikh home","children":[["$","span",null,{"className":"logo-mark","children":"C"}],["$","span",null,{"children":"C