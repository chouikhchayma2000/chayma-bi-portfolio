0:["8U7bpLhQ7ZpUIO6y-szL4",[[["",{"children":["projects",{"children":["adventureworks-incremental-data-warehouse",{"children":["__PAGE__",{}]}]}]},"$undefined","$undefined",true],["",{"children":["projects",{"children":["adventureworks-incremental-data-warehouse",{"children":["__PAGE__",{},[["$L1",["$","section",null,{"className":"section","children":["$","div",null,{"className":"container article","children":[["$","p",null,{"className":"breadcrumb","children":"Home / Projects / AdventureWorks Data Warehouse"}],["$","h1",null,{"children":"AdventureWorks Incremental Data Warehouse with SSIS"}],["$","img",null,{"className":"project-hero-image","src":"/images/adventureworks-project.svg","alt":"AdventureWorks incremental data warehouse SSIS ETL architecture"}],["$","p",null,{"children":"This Business Intelligence project presents the design and implementation of an incremental data warehouse using SQL Server Integration Services. The analysis is based on the AdventureWorks OLTP database and focuses on the purchasing process."}],["$","div",null,{"className":"kpi-grid","children":[["$","div",null,{"className":"kpi","children":[["$","strong",null,{"children":"SSIS"}],["$","span",null,{"children":"ETL pipeline"}]]}],["$","div",null,{"className":"kpi","children":[["$","strong",null,{"children":"Star"}],["$","span",null,{"children":"schema design"}]]}],["$","div",null,{"className":"kpi","children":[["$","strong",null,{"children":"Incremental"}],["$","span",null,{"children":"loading strategy"}]]}],["$","div",null,{"className":"kpi","children":[["$","strong",null,{"children":"KPIs"}],["$","span",null,{"children":"purchasing analysis"}]]}]]}],["$","h2",null,{"children":"Project Objective"}],["$","p",null,{"children":"The goal is to extract purchasing and product-related data, load it into staging tables, clean and transform it, then populate a dimensional model for purchasing performance analysis."}],["$","h2",null,{"children":"Extraction Phase"}],["$","p",null,{"children":"Data is extracted from AdventureWorks purchasing and production tables, including ship methods, vendors, purchase order headers, purchase order details, products, product subcategories and product categories. The extracted records are first loaded into staging tables."}],["$","h2",null,{"children":"Incremental Control"}],["$","p",null,{"children":"An incremental ETL approach is used. A control table stores the last extraction time for each source table. The extraction is based on the ModifiedDate column, which allows the process to load only new and updated records."}],["$","h2",null,{"children":"Transformation Phase"}],["$","ul",null,{"children":[["$","li",null,{"children":"Data profiling is executed on staging tables to detect quality issues."}],["$","li",null,{"children":"Null descriptive attributes are replaced with N/A."}],["$","li",null,{"children":"Missing Size and Color values are extracted from product names."}],["$","li",null,{"children":"Products with invalid pricing are redirected to a reject file."}],["$","li",null,{"children":"Duplicate vendors are removed and the most recent record is selected using ModifiedDate."}]]}],["$","h2",null,{"children":"Loading Phase and Star Schema"}],["$","p",null,{"children":"Dimension tables are loaded before the fact table. Surrogate keys are generated and lookup transformations are used to resolve dimension keys. The final star schema includes DimProduct, DimVendor, DimShipMethod, DimDate and a purchasing fact table."}],["$","h2",null,{"children":"Fact Table Grain and Measures"}],["$","p",null,{"children":"The fact table grain is one purchase order line for one product from one vendor on specific dates. Measures include order quantity, unit price, line total, received quantity, rejected quantity and stocked quantity."}],["$","h2",null,{"children":"Key Performance Indicators"}],["$","ul",null,{"children":[["$","li",null,{"children":"Total Ordered Quantity"}],["$","li",null,{"children":"Total Received Quantity"}],["$","li",null,{"children":"Total Rejected Quantity"}],["$","li",null,{"children":"Total Stocked Quantity"}],["$","li",null,{"children":"Order Fulfillment Rate"}],["$","li",null,{"children":"Rejection Rate"}],["$","li",null,{"children":"Inventory Acceptance Rate"}],["$","li",null,{"children":"Total Purchase Cost"}]]}]]}]}],null],null],null]},[null,["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children","projects","children","adventureworks-incremental-data-warehouse","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[null,["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children","projects","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/ba9020230c6dd994.css","precedence":"next","crossOrigin":"$undefined"}]],["$","html",null,{"lang":"en","children":["$","body",null,{"children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"Chayma Chouikh\",\"jobTitle\":\"BI Student and Data Analyst\",\"url\":\"https://your-domain.com\",\"sameAs\":[\"https://www.linkedin.com/in/chayma-chouikh/\"],\"knowsAbout\":[\"Business Intelligence\",\"Data Analysis\",\"SQL\",\"Power BI\",\"Python\",\"Machine Learning\",\"SSIS\",\"SSAS\",\"OLAP Cubes\",\"Data Warehousing\",\"Dashboards\",\"Reporting\"]}"}}],["$","header",null,{"className":"header","children":["$","nav",null,{"className":"container nav","aria-label":"Main navigation","children":[["$","$L4",null,{"href":"/","className":"logo","aria-label":"Chayma Chouikh ho